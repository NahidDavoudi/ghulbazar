# ─── Application ───────────────────────────────────────────────
APP_ENV=development
APP_BASE_PATH=/restApi

# ─── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=shop
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-access-token-secret
REFRESH_SECRET=change-me-refresh-token-secret

# ─── SMS Provider ──────────────────────────────────────────────
# Drivers: log (dev — writes to storage/logs/sms.log) | http (real panel)
SMS_DRIVER=log

# HTTP driver — fill in when your friend's SMS API docs arrive
SMS_API_URL=
SMS_API_METHOD=POST
SMS_API_KEY=
SMS_API_AUTH_PREFIX=Bearer
SMS_API_SENDER=
SMS_API_SENDER_FIELD=sender
SMS_API_PHONE_FIELD=mobile
SMS_API_MESSAGE_FIELD=message
SMS_API_TIMEOUT=10

# Optional: full JSON body template (overrides phone/message fields)
# Placeholders: {phone} {message}
# SMS_API_BODY={"mobile":"{phone}","message":"{message}","sender":"1000xxx"}

# Optional: extra headers as JSON
# SMS_API_HEADERS={"X-API-Key":"your-key"}

# OTP message template
SMS_OTP_TEMPLATE=کد تایید شما: {code}

# ─── Redis (optional — for future rate limiting) ───────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
