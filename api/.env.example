# ─── Application ───────────────────────────────────────────────
# production | development — در پروداکشن حتماً production باشد
APP_ENV=production
APP_BASE_PATH=/universal

# ─── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=shop
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ─── JWT ───────────────────────────────────────────────────────
# در پروداکشن حتماً مقادیر تصادفی قوی (حداقل ۳۲ کاراکتر) تنظیم کنید
JWT_SECRET=change-me-access-token-secret
REFRESH_SECRET=change-me-refresh-token-secret

# ─── SMS (Melipayamak Console — پیشنهادی) ─────────────────────
# log = فقط لاگ (توسعه) | melipayamak = ملی‌پیامک | http = سرویس سفارشی
SMS_DRIVER=melipayamak
MELIPAYAMAK_API_KEY=
MELIPAYAMAK_SENDER=
# MELIPAYAMAK_MODE=console   # console (پیش‌فرض) یا legacy برای REST قدیمی
# MELIPAYAMAK_USERNAME=      # فقط برای MELIPAYAMAK_MODE=legacy
SMS_OTP_TEMPLATE=کد تایید شما: {code}

# ─── SMS (HTTP سفارشی — اختیاری) ─────────────────────────────

# HTTP driver — fill in when your SMS API docs arrive
SMS_API_URL=
SMS_API_METHOD=POST
SMS_API_KEY=
SMS_API_AUTH_PREFIX=Bearer
SMS_API_SENDER=
SMS_API_SENDER_FIELD=sender
SMS_API_PHONE_FIELD=mobile
SMS_API_MESSAGE_FIELD=message
SMS_API_TIMEOUT=10

# Optional: full JSON body template (overrides phone/message fields)
# Placeholders: {phone} {message}
# SMS_API_BODY={"mobile":"{phone}","message":"{message}","sender":"1000xxx"}

# Optional: extra headers as JSON
# SMS_API_HEADERS={"X-API-Key":"your-key"}

# OTP message template
SMS_OTP_TEMPLATE=کد تایید شما: {code}

# ─── Uploads ───────────────────────────────────────────────────
# مسیر فیزیکی پوشه آپلود — در production اجباری و خارج از webroot
# UPLOAD_DIR=C:/xampp1/storage/universal-uploads
# URL عمومی فایل‌ها (اختیاری — پیش‌فرض: /uploads/)
# UPLOAD_PUBLIC_BASE=/universal/uploads

# ─── Redis (اختیاری — برای RateLimiter مبتنی بر Redis) ───────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
